# --- Dependencies ---
# Prevents leaking the 100MB+ node_modules folder
node_modules/
jspm_packages/

# --- Build & Output ---
# These are generated files and should not be on GitHub
out/
dist/
build/
bin/
*.tsbuildinfo
*.vsix

# --- Secrets & Config ---
# NEVER commit these files. They contain your API keys.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# If you use a specific vertex-agent config with secrets:
config/secrets.json

# --- IDE & Editor ---
# Local workspace settings that differ for every developer
.vscode/
.idea/
*.swp
*.swo
.history/

# --- Logs & Temp ---
# Keeps your repo clean from crash reports and logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
.npm/
.eslintcache

# --- OS Files ---
.DS_Store
Thumbs.db

.vertex