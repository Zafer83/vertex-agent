{
  "name": "vertex-agent",
  "displayName": "VertexAgent",
  "description": "VertexLabs AI Agent",
  "version": "1.7.82",
  "publisher": "vertexlabs",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCommand:vertexAgent.openChat",
    "onCommand:vertexAgent.openSettings"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Zafer83/vertex-agent.git"
  },
  "contributes": {
    "commands": [
      {
        "command": "vertexAgent.openChat",
        "title": "VertexAgent Chat",
        "icon": "media/icon.svg"
      },
      {
        "command": "vertexAgent.openSettings",
        "title": "VertexAgent Settings"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "vertexAgent.openChat",
          "group": "navigation"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vertexAgentSidebar",
          "title": "VertexAgent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "vertexAgentSidebar": [
        {
          "type": "webview",
          "id": "vertexAgentView",
          "name": "VertexAgent"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "VertexAgent",
      "properties": {
        "vertexAgent.provider": {
          "type": "string",
          "enum": [
            "openai",
            "gemini",
            "claude",
            "ollama",
            "custom"
          ],
          "default": "openai",
          "description": "LLM Provider."
        },
        "vertexAgent.serverUrl": {
          "type": "string",
          "default": "http://localhost",
          "description": "Base URL of your LLM server."
        },
        "vertexAgent.serverPort": {
          "type": "number",
          "default": 8080,
          "description": "Port of your LLM server."
        },
        "vertexAgent.apiKey": {
          "type": "string",
          "secret": true,
          "description": "API key for Gemini/Claude or compatible providers."
        },
        "vertexAgent.useAccessToken": {
          "type": "boolean",
          "default": false,
          "description": "Whether to use Bearer access token."
        },
        "vertexAgent.accessToken": {
          "type": "string",
          "secret": true,
          "description": "Bearer access token for OpenAI-compatible APIs."
        },
        "vertexAgent.temperature": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 2,
          "description": "Temperature for AI responses (0.0 = deterministic, 2.0 = creative)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node bump-version.js && node esbuild.js",
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "test": "npm run test:unit && npm run test:integration && npm run test:requirements",
    "test:unit": "node tests/unit/diff-logic.test.js && node tests/unit/system-prompt.test.js && node tests/unit/chat-html.test.js",
    "test:integration": "node tests/integration/full-pipeline.test.js && node tests/integration/llm-to-chat-pipeline.test.js",
    "test:requirements": "node tests/run-requirements.js",
    "test:watch": "nodemon --watch tests --watch src --exec npm test"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.27.4",
    "nodemon": "^3.1.0",
    "typescript": "^5.4.2",
    "undici": "^7.24.6"
  }
}
